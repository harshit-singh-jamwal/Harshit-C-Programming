#include <stdio.h>
#include <string.h>
#include <math.h>
#include <stdlib.h>

int main() {
int num,element=0,found=0;
    scanf("%d",&num);
    int arr[num];
    for(int i=0;i<num;i++){
        scanf("%d",&arr[i]);
    }
    scanf("%d",&element);
    for(int i=0;i<num;i++){
        if(arr[i]==element){
            printf("Element found at position %d",i+1);
            found=1;
            break;
        }
    }
    if(!found){
        printf("Element not found");
    }
    return 0;
}
