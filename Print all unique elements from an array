#include <stdio.h>
#include <string.h>
#include <math.h>
#include <stdlib.h>

int main() {
int num,found=0;
    scanf("%d",&num);
    int arr[num];
    for(int i=0;i<num;i++){
        scanf("%d",&arr[i]);
    }
    for(int i=0;i<num;i++){
        int count=0;
        for(int j=0;j<num;j++){
            if(arr[i]==arr[j]){
                count++;
            }
        }
        if(count==1){
            printf("%d ",arr[i]);
            found=1;
        }
    }
    if(!found){
        printf("No unique elements");
    }
    return 0;
}
