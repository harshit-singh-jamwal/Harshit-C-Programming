#include <stdio.h>
#include <string.h>
#include <math.h>
#include <stdlib.h>

int main() {
int num,num1,max=0;
    scanf("%d",&num);
    for(int i=0;i<num;i++){
        scanf("%d",&num1);
        if(i==0){
            max=num1;
        }
        else if(num1>max){
            max=num1;
        }
    }
    printf("%d\n",max);
    return 0;
}
