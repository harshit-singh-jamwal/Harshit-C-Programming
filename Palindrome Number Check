#include <stdio.h>
#include <string.h>
#include <math.h>
#include <stdlib.h>

int main() {
int num,reverse=0;
    scanf("%d",&num);
    if(num>=0 && num<=9){
        printf("%d",num);
    }
    else{
        int num1=num;
        while(num!=0){
            int rem=num%10;
            reverse=reverse*10+rem;
            num=num/10;
        }
        if(num1==reverse){
            printf("Palindrome");
        }
        else{
            printf("Not Palindrome");
        }
    }
    return 0;
}
