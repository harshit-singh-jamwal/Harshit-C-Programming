#include <stdio.h>

int main() {
    int N;
    scanf("%d", &N);

    int arr[100];

    for (int i = 0; i < N; i++) {
        scanf("%d", &arr[i]);
    }

    int position;
    scanf("%d", &position);

    if (position < 1 || position > N) {
        printf("Invalid position");
        return 0;
    }

    for (int i = position - 1; i < N - 1; i++) {
        arr[i] = arr[i + 1];
    }

    for (int i = 0; i < N - 1; i++) {
        printf("%d", arr[i]);
        if (i != N - 2)
            printf(" ");
    }

    return 0;
}
