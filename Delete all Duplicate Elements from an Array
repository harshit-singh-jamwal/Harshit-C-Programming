#include <stdio.h>
#include <string.h>
#include <math.h>
#include <stdlib.h>

int main() {
int num;
    scanf("%d",&num);
    int arr[num];
    for(int i=0;i<num;i++){
        scanf("%d",&arr[i]);
    }
    for(int i=0;i<num;i++){
        int found=0;
        for(int j=0;j<i;j++){
            if(arr[i]==arr[j]){
                found=1;
                break;
            }
        }
        if(!found){
            printf("%d ",arr[i]);
        }
    }
    return 0;
}
