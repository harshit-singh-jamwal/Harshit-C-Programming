#include <stdio.h>
#include <string.h>
#include <math.h>
#include <stdlib.h>

int main() {
int sub1,sub2,sub3,sub4,sub5;
    scanf("%d %d %d %d %d",&sub1,&sub2,&sub3,&sub4,&sub5);
    int total=sub1+sub2+sub3+sub4+sub5;
    float average=total/5;
    float percentage=(total*100)/500;
    printf("%d %.2f %.2f",total,average,percentage);
    return 0;
}
