#include <stdio.h>
#include <string.h>
#include <math.h>
#include <stdlib.h>

int main() {
int num;
    scanf("%d",&num);
    int arr[num];
    for(int i=0;i<num;i++){
        scanf("%d",&arr[i]);
    }
    int largest=arr[0];
    for(int i=0;i<num;i++){
        if(arr[i]>largest){
            largest=arr[i];
        }
    }
    printf("%d",largest);
    return 0;
}
